# Database (Prisma + Supabase Postgres)
# Use Supavisor Session pooler (port 5432) for IPv4/IPv6 compatibility.
# In Supabase Dashboard: Connect -> ORMs -> Prisma.
SUPABASE_DB_URL=postgresql://postgres.your-project-ref:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres?sslmode=require&uselibpqcompat=true&schema=public
AUTH_JWT_SECRET=ruasa-local-jwt-secret-change-me
AUTH_ACCESS_TOKEN_EXPIRES_IN_SECONDS=300

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App server (Nuxt dev/prod)
PORT=3010
NODE_ENV=development

# Public runtime config (available on client)
NUXT_PUBLIC_APP_NAME=Nuxt Enterprise Template
# Optional. If empty, resolves automatically to http://127.0.0.1:${PORT}
NUXT_PUBLIC_APP_URL=
# Optional. If empty, falls back to NUXT_PUBLIC_APP_URL
NUXT_PUBLIC_API_URL=
