# Database (Prisma)
DATABASE_URL=postgresql://postgres:postgres@db:5432/app_db?schema=public
DIRECT_URL=postgresql://postgres:postgres@db:5432/app_db?schema=public

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# App server (Nuxt dev/prod)
PORT=3000
NODE_ENV=development

# Public runtime config (available on client)
NUXT_PUBLIC_APP_NAME=Nuxt Enterprise Template
# Optional. If empty, resolves automatically to http://127.0.0.1:${PORT}
NUXT_PUBLIC_APP_URL=
# Optional. If empty, falls back to NUXT_PUBLIC_APP_URL
NUXT_PUBLIC_API_URL=
