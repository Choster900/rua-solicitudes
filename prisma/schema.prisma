generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

/**
 * =========================
 * ENUMS
 * =========================
 */

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum RequestStatus {
  CREATED
  PENDING_DESIGN_REVIEW
  ASSIGNED_TO_DESIGNER
  IN_DESIGN
  SENT_TO_QUALITY
  QUALITY_REJECTED
  QUALITY_APPROVED
  DELIVERED_TO_SALES
  CANCELLED
}

enum RequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VersionStatus {
  IN_DESIGN
  SENT_TO_QUALITY
  REJECTED
  APPROVED
  CLOSED
}

enum VersionReason {
  INITIAL
  QUALITY_REJECTION
  MANUAL_CORRECTION
}

enum AssignmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum QualityDecision {
  APPROVED
  REJECTED
}

enum FileOrigin {
  SALES
  DESIGN
  QUALITY
}

enum FileCategory {
  SALES_REFERENCE
  DESIGN_SOURCE
  DESIGN_OUTPUT
  QUALITY_EVIDENCE
  FINAL_DELIVERABLE
  OTHER
}

enum WorkflowAction {
  CREATED
  REVIEWED_BY_DESIGN_LEAD
  ASSIGNED_DESIGNER
  SENT_TO_QUALITY
  QUALITY_REJECTED
  VERSION_CREATED
  QUALITY_APPROVED
  DELIVERED_TO_SALES
  CANCELLED
}

/**
 * =========================
 * AUTH
 * =========================
 */

model AuthUser {
  id                 String     @id @default(cuid())
  employeeCode       String     @unique
  fullName           String
  email              String     @unique
  phone              String     @default("")
  department         String?
  status             UserStatus @default(ACTIVE)
  passwordHash       String
  mustChangePassword Boolean    @default(true)
  lastAccessAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  // Solicitudes creadas por el vendedor
  salesRequests DesignRequest[] @relation("RequestSeller")

  // Versiones creadas por usuarios
  createdVersions DesignRequestVersion[] @relation("VersionCreatedBy")

  // Asignaciones de diseño
  designerAssignments RequestDesignerAssignment[] @relation("AssignedDesigner")
  assignmentsMade     RequestDesignerAssignment[] @relation("AssignedBy")

  // Calidad
  qualityReviews QualityReview[] @relation("QualityReviewedBy")

  // Archivos
  uploadedFiles RequestFile[] @relation("FileUploadedBy")

  // Historial
  workflowEvents RequestWorkflowEvent[] @relation("WorkflowActor")

  @@index([status])
  @@index([department])
}

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  code        String  @unique
  description String?
  isSystem    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userRoles UserRole[]

  @@index([code])
  @@index([isSystem])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())

  user AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

/**
 * =========================
 * CLIENTES
 * =========================
 */

model Client {
  id    String  @id @default(cuid())
  code  String  @unique
  name  String
  taxId String? @unique

  contactName  String?
  contactEmail String?
  contactPhone String?

  country          String?
  department       String?
  city             String?
  addressLine      String?
  addressReference String  @default("")

  notes    String  @default("")
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  designRequests DesignRequest[]

  @@index([name])
  @@index([isActive])
}

/**
 * =========================
 * SOLICITUD PRINCIPAL
 * =========================
 */

model DesignRequest {
  id   String @id @default(cuid())
  code String @unique

  // Cliente para quien se hace la solicitud
  clientId String

  // Vendedor que creó la solicitud
  sellerId String

  title       String
  brandName   String
  productName String

  priority RequestPriority @default(MEDIUM)
  status   RequestStatus   @default(CREATED)

  requiredDate DateTime?
  closedAt     DateTime?
  cancelledAt  DateTime?

  currentVersionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client   @relation(fields: [clientId], references: [id])
  seller AuthUser @relation("RequestSeller", fields: [sellerId], references: [id])

  currentVersion DesignRequestVersion? @relation("CurrentRequestVersion", fields: [currentVersionId], references: [id], onDelete: SetNull)

  versions       DesignRequestVersion[] @relation("RequestVersions")
  files          RequestFile[]
  workflowEvents RequestWorkflowEvent[]

  @@index([clientId])
  @@index([sellerId])
  @@index([status])
  @@index([priority])
  @@index([requiredDate])
  @@index([createdAt])
}

/**
 * =========================
 * VERSIONES DE LA SOLICITUD
 * =========================
 */

model DesignRequestVersion {
  id String @id @default(cuid())

  requestId     String
  versionNumber Int

  basedOnVersionId String?
  createdById      String

  reason VersionReason @default(INITIAL)
  status VersionStatus @default(IN_DESIGN)

  materialType   String?
  materialWeight String?
  closureType    String?
  fluteType      String?
  fluteDirection String?

  outerLiner String?
  innerLiner String?

  printTechnique    String?
  colorMode         String?
  pantoneReferences String?

  length        Decimal? @db.Decimal(10, 2)
  width         Decimal? @db.Decimal(10, 2)
  height        Decimal? @db.Decimal(10, 2)
  dimensionUnit String   @default("cm")

  quantity Int?

  finishingOptions String[] @default([])
  deliverables     String[] @default([])

  designInstructions String @default("")
  visualReferences   String @default("")

  requireDieCut Boolean @default(false)
  requireMockup Boolean @default(false)

  // Checklist interno de diseño antes de enviar a calidad
  artCompleted        Boolean @default(false)
  mechanicalCompleted Boolean @default(false)
  dummyCompleted      Boolean @default(false)

  artCompletedAt        DateTime?
  mechanicalCompletedAt DateTime?
  dummyCompletedAt      DateTime?

  submittedToQualityAt DateTime?
  approvedAt           DateTime?
  rejectedAt           DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request   DesignRequest @relation("RequestVersions", fields: [requestId], references: [id], onDelete: Cascade)
  createdBy AuthUser      @relation("VersionCreatedBy", fields: [createdById], references: [id])

  basedOnVersion  DesignRequestVersion?  @relation("VersionHistory", fields: [basedOnVersionId], references: [id], onDelete: SetNull)
  derivedVersions DesignRequestVersion[] @relation("VersionHistory")

  currentForRequests DesignRequest[] @relation("CurrentRequestVersion")

  assignments    RequestDesignerAssignment[]
  files          RequestFile[]
  qualityReviews QualityReview[]
  workflowEvents RequestWorkflowEvent[]

  @@unique([requestId, versionNumber])
  @@index([requestId])
  @@index([status])
  @@index([basedOnVersionId])
  @@index([createdById])
}

/**
 * =========================
 * ASIGNACIÓN DE DISEÑADORES
 * =========================
 */

model RequestDesignerAssignment {
  id String @id @default(cuid())

  versionId    String
  designerId   String
  assignedById String

  isLeadDesigner Boolean @default(false)

  status AssignmentStatus @default(ACTIVE)
  notes  String           @default("")

  assignedAt  DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  version    DesignRequestVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  designer   AuthUser             @relation("AssignedDesigner", fields: [designerId], references: [id])
  assignedBy AuthUser             @relation("AssignedBy", fields: [assignedById], references: [id])

  @@unique([versionId, designerId])
  @@index([versionId])
  @@index([designerId])
  @@index([assignedById])
  @@index([status])
}

/**
 * =========================
 * REVISIÓN DE CALIDAD
 * =========================
 */

model QualityReview {
  id String @id @default(cuid())

  versionId    String
  reviewedById String

  decision            QualityDecision
  generalObservations String          @default("")

  checklist Json?

  reviewedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  version    DesignRequestVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)
  reviewedBy AuthUser             @relation("QualityReviewedBy", fields: [reviewedById], references: [id])

  @@index([versionId])
  @@index([reviewedById])
  @@index([decision])
  @@index([reviewedAt])
}

/**
 * =========================
 * ARCHIVOS
 * =========================
 */

model RequestFile {
  id String @id @default(cuid())

  requestId String
  versionId String?

  uploadedById String

  origin   FileOrigin
  category FileCategory

  originalName  String
  mimeType      String
  sizeBytes     BigInt
  base64Content String   @db.Text

  notes    String  @default("")
  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  request    DesignRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  version    DesignRequestVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  uploadedBy AuthUser              @relation("FileUploadedBy", fields: [uploadedById], references: [id])

  @@index([requestId])
  @@index([versionId])
  @@index([uploadedById])
  @@index([origin])
  @@index([category])
  @@index([isActive])
  @@index([createdAt])
}

/**
 * =========================
 * HISTORIAL DEL FLUJO
 * =========================
 */

model RequestWorkflowEvent {
  id String @id @default(cuid())

  requestId String
  versionId String?

  actorId String?

  action WorkflowAction

  fromRequestStatus RequestStatus?
  toRequestStatus   RequestStatus?

  fromVersionStatus VersionStatus?
  toVersionStatus   VersionStatus?

  comments String @default("")
  metadata Json?

  createdAt DateTime @default(now())

  request DesignRequest         @relation(fields: [requestId], references: [id], onDelete: Cascade)
  version DesignRequestVersion? @relation(fields: [versionId], references: [id], onDelete: Cascade)
  actor   AuthUser?             @relation("WorkflowActor", fields: [actorId], references: [id])

  @@index([requestId])
  @@index([versionId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
}