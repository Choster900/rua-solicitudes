generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  username     String?    @unique
  passwordHash String
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  userRoles    UserRole[]

  @@index([isActive])
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  code            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isSystem])
}

model Permission {
  id              String           @id @default(uuid())
  name            String
  code            String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@index([assignedBy])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@index([grantedBy])
}

model AuthUser {
  id                 String    @id @default(cuid())
  employeeCode       String    @unique
  fullName           String
  email              String    @unique
  phone              String    @default("")
  userType           String
  department         String
  status             String
  password           String
  mustChangePassword Boolean   @default(true)
  lastAccessAt       DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  createdRequests  DesignRequest[]        @relation("RequestCreator")
  assignedRequests DesignRequest[]        @relation("RequestDesigner")
  leadAssignments  DesignRequest[]        @relation("RequestAssigner")
  approvedRequests DesignRequest[]        @relation("RequestApprover")
  designedVersions DesignRequestVersion[] @relation("VersionDesigner")
  reviewedVersions DesignRequestVersion[] @relation("VersionReviewer")
  requestEvents    DesignRequestEvent[]   @relation("RequestEventActor")

  @@index([status])
  @@index([userType])
}

model Client {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  taxId            String   @unique
  segment          String
  contactName      String
  contactEmail     String
  contactPhone     String
  country          String
  department       String
  city             String
  addressLine      String
  addressReference String   @default("")
  website          String   @default("")
  googleMapsUrl    String   @default("")
  notes            String   @default("")
  status           String   @default("Prospecto")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
}

model Vendor {
  id                  String   @id @default(cuid())
  code                String   @unique
  fullName            String
  zone                String
  phone               String
  email               String
  assignedClientCodes Json
  monthlySalesUsd     Int
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model DesignRequest {
  id          String @id @default(cuid())
  requestCode String @unique

  // Quién creó la solicitud (vendedor)
  createdById String?
  requestedBy String
  vendorName  String

  // Contexto del cliente
  clientName  String
  brandName   String
  productName String

  // Especificaciones técnicas
  materialType      String
  materialWeight    String
  fluteDirection    String   @default("")
  outerLiner        String   @default("")
  innerLiner        String   @default("")
  printTechnique    String
  colorMode         String
  pantoneReferences String   @default("")
  finishingOptions  Json
  deliverables      Json
  dimensions        String
  quantity          Int
  requiredDate      DateTime
  priority          String

  // Estado del flujo
  // PENDING_ASSIGNMENT | ASSIGNED | IN_DESIGN | IN_QUALITY_REVIEW | APPROVED | REJECTED
  status         String
  currentVersion Int    @default(1)

  // Asignación (la hace el jefe de diseño)
  assignedDesignerId String?
  assignedById       String?
  assignedAt         DateTime?

  // Aprobación final (calidad)
  approvedById String?
  approvedAt   DateTime?

  // Detalles de la solicitud
  designInstructions String  @default("")
  visualReferences   String  @default("")
  requireArt         Boolean @default(true)
  requireDieCut      Boolean @default(false)
  requireMockup      Boolean @default(false)
  attachments        Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workflow RequestWorkflow?
  versions DesignRequestVersion[]
  events   DesignRequestEvent[]

  creator          AuthUser? @relation("RequestCreator", fields: [createdById], references: [id])
  assignedDesigner AuthUser? @relation("RequestDesigner", fields: [assignedDesignerId], references: [id])
  assigner         AuthUser? @relation("RequestAssigner", fields: [assignedById], references: [id])
  approver         AuthUser? @relation("RequestApprover", fields: [approvedById], references: [id])

  @@index([status])
  @@index([priority])
  @@index([createdById])
  @@index([assignedDesignerId])
  @@index([assignedById])
  @@index([approvedById])
}

model DesignRequestVersion {
  id            String @id @default(cuid())
  requestId     String
  versionNumber Int
  designerId    String

  artFiles      Json      @default("[]")
  designerNotes String    @default("")
  submittedAt   DateTime?

  // PENDING | APPROVED | REJECTED
  reviewStatus    String    @default("PENDING")
  reviewedById    String?
  reviewedAt      DateTime?
  rejectionReason String    @default("")
  reviewComments  String    @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request  DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  designer AuthUser      @relation("VersionDesigner", fields: [designerId], references: [id])
  reviewer AuthUser?     @relation("VersionReviewer", fields: [reviewedById], references: [id])

  @@unique([requestId, versionNumber])
  @@index([requestId])
  @@index([designerId])
  @@index([reviewedById])
  @@index([reviewStatus])
}

model DesignRequestEvent {
  id        String @id @default(cuid())
  requestId String

  // CREATED | ASSIGNED | REASSIGNED | DESIGN_STARTED | ART_SUBMITTED |
  // QUALITY_APPROVED | QUALITY_REJECTED | VERSION_CREATED | COMMENT
  eventType  String
  actorId    String?
  fromStatus String?
  toStatus   String?
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  request DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  actor   AuthUser?     @relation("RequestEventActor", fields: [actorId], references: [id])

  @@index([requestId])
  @@index([eventType])
  @@index([actorId])
  @@index([createdAt])
}

model RequestWorkflow {
  id           String        @id @default(cuid())
  requestId    String        @unique
  stage        String
  checklist    Json
  observations Json
  auditTrail   Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  request      DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([stage])
}

model RequestClosureType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFluteType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFluteDirection {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFinishingOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}
