generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AuthUser {
  id                 String     @id @default(cuid())
  employeeCode       String     @unique
  fullName           String
  email              String     @unique
  phone              String     @default("")
  department         String
  status             String
  passwordHash       String
  mustChangePassword Boolean    @default(true)
  lastAccessAt       DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  userRoles          UserRole[]

  @@index([status])
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  code            String           @unique
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isSystem])
}

model Permission {
  id              String           @id @default(uuid())
  name            String
  code            String           @unique
  resource        String
  action          String
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@index([action])
}

model UserRole {
  id         String   @id @default(uuid())
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  assignedBy String?
  user       AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([roleId])
  @@index([assignedBy])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  grantedAt    DateTime   @default(now())
  grantedBy    String?
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
  @@index([grantedBy])
}

model Client {
  id               String   @id @default(cuid())
  code             String   @unique
  name             String
  taxId            String   @unique
  segment          String
  contactName      String
  contactEmail     String
  contactPhone     String
  country          String
  department       String
  city             String
  addressLine      String
  addressReference String   @default("")
  website          String   @default("")
  googleMapsUrl    String   @default("")
  notes            String   @default("")
  status           String   @default("Prospecto")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([status])
}

model Vendor {
  id                  String   @id @default(cuid())
  code                String   @unique
  fullName            String
  zone                String
  phone               String
  email               String
  assignedClientCodes Json
  monthlySalesUsd     Int
  status              String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([status])
}

model DesignRequest {
  id          String @id @default(cuid())
  requestCode String @unique

  // Quién creó la solicitud (vendedor)
  createdById String?
  requestedBy String
  vendorName  String

  // Contexto del cliente
  clientName  String
  brandName   String
  productName String

  // Especificaciones técnicas
  materialType      String
  materialWeight    String
  fluteDirection    String   @default("")
  outerLiner        String   @default("")
  innerLiner        String   @default("")
  printTechnique    String
  colorMode         String
  pantoneReferences String   @default("")
  finishingOptions  Json
  deliverables      Json
  dimensions        String
  quantity          Int
  requiredDate      DateTime
  priority          String
  status            String
  designInstructions   String          @default("")
  visualReferences     String          @default("")
  requireDieCut        Boolean         @default(false)
  requireMockup        Boolean         @default(false)
  attachments          Json
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  workflow             RequestWorkflow?
  designerAssignments  RequestDesignerAssignment[]

  @@index([status])
  @@index([priority])
}

model RequestDesignerAssignment {
  id           String        @id @default(cuid())
  requestId    String
  designerId   String
  designerName String        @default("")
  assignedAt   DateTime      @default(now())
  assignedById String?
  request      DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@unique([requestId, designerId])
  @@index([requestId])
  @@index([designerId])
}

model RequestWorkflow {
  id           String        @id @default(cuid())
  requestId    String        @unique
  stage        String
  checklist    Json
  observations Json
  auditTrail   Json
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  request      DesignRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([stage])
}

model RequestClosureType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFluteType {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFluteDirection {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model RequestFinishingOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}
